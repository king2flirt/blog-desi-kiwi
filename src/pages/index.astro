---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="The Archive - Sustainable, Mindful, Open" useTitleTemplate={false}>
  
  <section class="container mx-auto px-4 py-12 lg:py-24 flex flex-col lg:flex-row items-center gap-12">
    <div class="lg:w-1/2">
      <Heading level="h1" class="text-5xl lg:text-6xl font-bold leading-tight mb-6 text-neutral-900 dark:text-neutral-100">
        Ideas, skills and perspectives for a better life — on <span class="text-green-700 dark:text-green-500 italic">our</span> terms.
      </Heading>
      <p class="text-xl mb-8 text-neutral-700 dark:text-neutral-300">
        A personal blog exploring sustainable living, open-source tech, community, and the mind — from Aotearoa and beyond.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/start-here" class="px-6 py-3 bg-green-700 text-white rounded-md font-medium hover:bg-green-800 transition shadow-sm focus:ring-2 focus:ring-offset-2 focus:ring-green-700 dark:focus:ring-offset-neutral-900">
          Start Here &rarr;
        </a>
        <a href="/topics" class="px-6 py-3 border border-neutral-300 dark:border-neutral-600 rounded-md font-medium hover:bg-neutral-50 dark:hover:bg-neutral-800 transition focus:ring-2 focus:ring-offset-2 focus:ring-neutral-500 dark:focus:ring-offset-neutral-900 text-neutral-900 dark:text-neutral-100">
          Explore All Topics
        </a>
      </div>
    </div>
    <div class="lg:w-1/2 w-full">
      <img 
        src="https://images.unsplash.com/photo-1469521669194-babbdf9071b2?q=80&w=1600&auto=format&fit=crop" 
        alt="Coastal landscape in Aotearoa during golden hour" 
        class="rounded-xl shadow-lg w-full object-cover aspect-video"
      />
    </div>
  </section>

  <section class="container mx-auto px-4 py-8 border-y border-neutral-200 dark:border-neutral-800 mb-16" aria-label="Key Site Features">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center lg:text-left">
      <div class="flex flex-col lg:flex-row items-center gap-3">
        <div class="p-3 bg-neutral-100 dark:bg-neutral-800 rounded-full text-green-700 dark:text-green-500" aria-hidden="true">
          <Icon name="lucide:leaf" size="1.5rem" />
        </div>
        <div>
          <Heading level="h2" class="font-bold text-sm m-0 text-neutral-900 dark:text-neutral-100">Independent & Open</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400">No corporate strings.</p>
        </div>
      </div>
      <div class="flex flex-col lg:flex-row items-center gap-3">
        <div class="p-3 bg-neutral-100 dark:bg-neutral-800 rounded-full text-blue-700 dark:text-blue-500" aria-hidden="true">
          <Icon name="lucide:layout-grid" size="1.5rem" />
        </div>
        <div>
          <Heading level="h2" class="font-bold text-sm m-0 text-neutral-900 dark:text-neutral-100">Wide Range of Topics</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400">Gardening to homelabs.</p>
        </div>
      </div>
      <div class="flex flex-col lg:flex-row items-center gap-3">
        <div class="p-3 bg-neutral-100 dark:bg-neutral-800 rounded-full text-purple-700 dark:text-purple-500" aria-hidden="true">
          <Icon name="lucide:user" size="1.5rem" />
        </div>
        <div>
          <Heading level="h2" class="font-bold text-sm m-0 text-neutral-900 dark:text-neutral-100">Practical & Real</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400">Actionable guides & notes.</p>
        </div>
      </div>
      <div class="flex flex-col lg:flex-row items-center gap-3">
        <div class="p-3 bg-neutral-100 dark:bg-neutral-800 rounded-full text-orange-700 dark:text-orange-500" aria-hidden="true">
          <Icon name="lucide:map-pin" size="1.5rem" />
        </div>
        <div>
          <Heading level="h2" class="font-bold text-sm m-0 text-neutral-900 dark:text-neutral-100">Rooted in NZ</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400">Based in Aotearoa.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 space-y-12">
    
    <section class="bg-green-50/50 dark:bg-green-900/10 rounded-2xl p-6 lg:p-8 flex flex-col lg:flex-row gap-8 border border-green-100 dark:border-green-900/30">
      <div class="lg:w-1/4">
        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-400 rounded-full flex items-center justify-center mb-4" aria-hidden="true">
          <Icon name="lucide:trees" size="1.5rem" />
        </div>
        <p class="text-xs font-bold uppercase tracking-wider text-neutral-500 mb-1" aria-hidden="true">Pillar 1</p>
        <Heading level="h2" class="text-3xl font-bold mb-3 text-neutral-900 dark:text-neutral-100">The Earth</Heading>
        <p class="text-neutral-600 dark:text-neutral-400 mb-6 text-sm">Sustainable, mindful living in Aotearoa.</p>
        <a href="/earth" class="inline-block px-4 py-2 bg-green-700 text-white rounded-md text-sm font-medium hover:bg-green-800 focus:ring-2 focus:ring-offset-2 focus:ring-green-700 dark:focus:ring-offset-neutral-900 transition">Explore all topics &rarr;</a>
      </div>

      <div class="lg:w-3/4 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 flex items-center gap-2 text-neutral-900 dark:text-neutral-100">Gardening</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-4 h-8">Grow food, nurture the soil, and work with the seasons.</p>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-green-700 dark:hover:text-green-400 transition underline-offset-4 hover:underline">What to Plant in Autumn in Aotearoa</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-green-700 dark:hover:text-green-400 transition underline-offset-4 hover:underline">Winter Gardening Checklist</a></li>
          </ul>
          <a href="/gardening" class="text-sm font-medium text-green-700 dark:text-green-400 hover:underline">View all Gardening &rarr;</a>
        </div>
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 flex items-center gap-2 text-neutral-900 dark:text-neutral-100">Life</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-4 h-8">Mindful living, community, and personal growth.</p>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-green-700 dark:hover:text-green-400 transition underline-offset-4 hover:underline">Budgeting for Financial Freedom</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-green-700 dark:hover:text-green-400 transition underline-offset-4 hover:underline">Yoga for a Clear Mind</a></li>
          </ul>
          <a href="/life" class="text-sm font-medium text-green-700 dark:text-green-400 hover:underline">View all Life &rarr;</a>
        </div>
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 flex items-center gap-2 text-neutral-900 dark:text-neutral-100">Work</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-4 h-8">Work, study, and build a life that supports you.</p>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-green-700 dark:hover:text-green-400 transition underline-offset-4 hover:underline">Community Support Work in NZ</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-green-700 dark:hover:text-green-400 transition underline-offset-4 hover:underline">Building Skills That Matter</a></li>
          </ul>
          <a href="/work" class="text-sm font-medium text-green-700 dark:text-green-400 hover:underline">View all Work &rarr;</a>
        </div>
      </div>
    </section>

    <section class="bg-blue-50/50 dark:bg-blue-900/10 rounded-2xl p-6 lg:p-8 flex flex-col lg:flex-row gap-8 border border-blue-100 dark:border-blue-900/30">
      <div class="lg:w-1/4">
        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-400 rounded-full flex items-center justify-center mb-4" aria-hidden="true">
          <Icon name="lucide:monitor" size="1.5rem" />
        </div>
        <p class="text-xs font-bold uppercase tracking-wider text-neutral-500 mb-1" aria-hidden="true">Pillar 2</p>
        <Heading level="h2" class="text-3xl font-bold mb-3 text-neutral-900 dark:text-neutral-100">The Wire</Heading>
        <p class="text-neutral-600 dark:text-neutral-400 mb-6 text-sm">Digital sovereignty and "building it yourself."</p>
        <a href="/wire" class="inline-block px-4 py-2 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700 focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 dark:focus:ring-offset-neutral-900 transition">Explore all topics &rarr;</a>
      </div>

      <div class="lg:w-3/4 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 flex items-center gap-2 text-neutral-900 dark:text-neutral-100">Digital Sovereignty</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-4 h-8">Own your data, your devices, your freedom.</p>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-blue-600 dark:hover:text-blue-400 transition underline-offset-4 hover:underline">Proxmox Setup Guide</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-blue-600 dark:hover:text-blue-400 transition underline-offset-4 hover:underline">Linux Distro Reviews</a></li>
          </ul>
          <a href="/digital-sovereignty" class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline">View all Digital Sovereignty &rarr;</a>
        </div>
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 flex items-center gap-2 text-neutral-900 dark:text-neutral-100">DIY Tech / Projects</Heading>
          <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-4 h-8">Hands-on projects, homelab, and tech experiments.</p>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-blue-600 dark:hover:text-blue-400 transition underline-offset-4 hover:underline">Setting up a HomeLab on a Budget</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-blue-600 dark:hover:text-blue-400 transition underline-offset-4 hover:underline">DIY NAS with Open Source</a></li>
          </ul>
          <a href="/diy-tech" class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline">View all DIY Tech / Projects &rarr;</a>
        </div>
      </div>
    </section>

    <section class="bg-purple-50/50 dark:bg-purple-900/10 rounded-2xl p-6 lg:p-8 flex flex-col lg:flex-row gap-8 border border-purple-100 dark:border-purple-900/30">
      <div class="lg:w-1/4">
        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/50 text-purple-700 dark:text-purple-400 rounded-full flex items-center justify-center mb-4" aria-hidden="true">
          <Icon name="lucide:brain" size="1.5rem" />
        </div>
        <p class="text-xs font-bold uppercase tracking-wider text-neutral-500 mb-1" aria-hidden="true">Pillar 3</p>
        <Heading level="h2" class="text-3xl font-bold mb-3 text-neutral-900 dark:text-neutral-100">Mind & Machine</Heading>
        <p class="text-neutral-600 dark:text-neutral-400 mb-6 text-sm">Understanding how the world (and we) work.</p>
        <a href="/mind-machine" class="inline-block px-4 py-2 bg-purple-600 text-white rounded-md text-sm font-medium hover:bg-purple-700 focus:ring-2 focus:ring-offset-2 focus:ring-purple-600 dark:focus:ring-offset-neutral-900 transition">Explore all topics &rarr;</a>
      </div>

      <div class="lg:w-3/4 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 text-neutral-900 dark:text-neutral-100">Thoughts / Opinions</Heading>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3 mt-4">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-purple-600 dark:hover:text-purple-400 transition underline-offset-4 hover:underline">Why We Think in Biases</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-purple-600 dark:hover:text-purple-400 transition underline-offset-4 hover:underline">The Attention Economy</a></li>
          </ul>
          <a href="/thoughts" class="text-sm font-medium text-purple-600 dark:text-purple-400 hover:underline">View all Thoughts &rarr;</a>
        </div>
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 text-neutral-900 dark:text-neutral-100">Politics / News</Heading>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3 mt-4">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-purple-600 dark:hover:text-purple-400 transition underline-offset-4 hover:underline">Local Politics in NZ</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-purple-600 dark:hover:text-purple-400 transition underline-offset-4 hover:underline">Digital Rights and Freedom</a></li>
          </ul>
          <a href="/politics" class="text-sm font-medium text-purple-600 dark:text-purple-400 hover:underline">View all Politics &rarr;</a>
        </div>
        <div>
          <Heading level="h3" class="text-lg font-bold mb-2 text-neutral-900 dark:text-neutral-100">Sanatan</Heading>
          <Heading level="h4" class="text-xs font-bold uppercase text-neutral-500 mb-3 mt-4">Latest posts</Heading>
          <ul class="space-y-2 mb-4">
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-purple-600 dark:hover:text-purple-400 transition underline-offset-4 hover:underline">The Bhagavad Gita in Daily Life</a></li>
            <li><a href="#" class="text-sm text-neutral-800 dark:text-neutral-300 hover:text-purple-600 dark:hover:text-purple-400 transition underline-offset-4 hover:underline">Hari Krishna in Christchurch</a></li>
          </ul>
          <a href="/sanatan" class="text-sm font-medium text-purple-600 dark:text-purple-400 hover:underline">View all Sanatan &rarr;</a>
        </div>
      </div>
    </section>
  </div>

  <section class="container mx-auto px-4 py-20">
    <div class="flex justify-between items-end mb-8 border-b border-neutral-200 dark:border-neutral-800 pb-4">
      <div>
        <Heading level="h2" class="text-2xl font-bold flex items-center gap-2 text-neutral-900 dark:text-neutral-100">
          <Icon name="lucide:book-open" size="1.5rem" aria-hidden="true" /> Featured Reads
        </Heading>
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mt-1">Hand-picked articles from across the archive.</p>
      </div>
      <a href="/archive" class="text-sm font-medium hover:underline text-neutral-900 dark:text-neutral-100 hidden md:block focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-neutral-500 dark:focus:ring-offset-neutral-900 rounded">View all featured &rarr;</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <article class="group relative flex flex-col focus-within:ring-2 focus-within:ring-green-700 dark:focus-within:ring-green-500 focus-within:ring-offset-4 dark:focus-within:ring-offset-neutral-900 rounded-lg">
        <div class="overflow-hidden rounded-lg mb-4 aspect-[4/3] bg-neutral-100 dark:bg-neutral-800">
          <img src="https://images.unsplash.com/photo-1592424001806-0391104e1713?q=80&w=800&auto=format&fit=crop" alt="Raised garden beds" class="w-full h-full object-cover group-hover:scale-105 transition duration-300" />
        </div>
        <div>
          <span class="text-xs font-bold text-green-700 dark:text-green-400 bg-green-100 dark:bg-green-900/30 px-2 py-1 rounded">Gardening</span>
          <Heading level="h3" class="font-bold text-lg mt-2 mb-1 text-neutral-900 dark:text-neutral-100 group-hover:text-green-700 dark:group-hover:text-green-400 transition">
            <a href="#" class="focus:outline-none before:absolute before:inset-0">What to Plant in Autumn in Aotearoa</a>
          </Heading>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-2 line-clamp-2">A seasonal guide to planting for abundance and preparing your soil.</p>
          <div class="text-xs text-neutral-500">May 12, 2026 • 8 min read</div>
        </div>
      </article>

      <article class="group relative flex flex-col focus-within:ring-2 focus-within:ring-blue-600 dark:focus-within:ring-blue-400 focus-within:ring-offset-4 dark:focus-within:ring-offset-neutral-900 rounded-lg">
        <div class="overflow-hidden rounded-lg mb-4 aspect-[4/3] bg-neutral-100 dark:bg-neutral-800">
          <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?q=80&w=800&auto=format&fit=crop" alt="Server rack lights" class="w-full h-full object-cover group-hover:scale-105 transition duration-300" />
        </div>
        <div>
          <span class="text-xs font-bold text-blue-700 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/30 px-2 py-1 rounded">Tech</span>
          <Heading level="h3" class="font-bold text-lg mt-2 mb-1 text-neutral-900 dark:text-neutral-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">
            <a href="#" class="focus:outline-none before:absolute before:inset-0">Setting up a HomeLab on a Budget</a>
          </Heading>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-2 line-clamp-2">Build your own self-hosted infrastructure with mini PCs and Docker.</p>
          <div class="text-xs text-neutral-500">May 10, 2026 • 10 min read</div>
        </div>
      </article>
      
      </div>
  </section>

  <section class="container mx-auto px-4 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <div class="lg:col-span-2 bg-neutral-50 dark:bg-neutral-900 rounded-2xl p-8 flex flex-col md:flex-row items-center gap-8 border border-neutral-200 dark:border-neutral-800">
        <div class="w-16 h-16 bg-white dark:bg-neutral-800 rounded-full flex items-center justify-center text-green-700 dark:text-green-500 shadow-sm shrink-0" aria-hidden="true">
          <Icon name="lucide:mail" size="2rem" />
        </div>
        <div class="flex-grow w-full">
          <Heading level="h2" class="text-xl font-bold mb-1 text-neutral-900 dark:text-neutral-100">Stay in the loop</Heading>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-4">Get new posts and updates straight to your inbox.</p>
          <form class="flex flex-col sm:flex-row gap-2 w-full max-w-md" action="#" method="POST">
            <label for="email-address" class="sr-only">Email address</label>
            <input 
              id="email-address" 
              name="email" 
              type="email" 
              autocomplete="email" 
              required 
              placeholder="Your email address" 
              class="flex-grow px-4 py-2 rounded-md border border-neutral-300 dark:border-neutral-700 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-green-700 dark:focus:ring-green-500" 
            />
            <button type="submit" class="px-6 py-2 bg-green-700 text-white rounded-md font-medium hover:bg-green-800 transition focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-700 dark:focus:ring-offset-neutral-900">Subscribe</button>
          </form>
          <p class="text-xs text-neutral-500 mt-2">No spam. Unsubscribe anytime.</p>
        </div>
      </div>

      <div class="bg-neutral-50 dark:bg-neutral-900 rounded-2xl p-8 border border-neutral-200 dark:border-neutral-800 flex flex-col justify-center">
        <Heading level="h2" class="text-lg font-bold mb-2 text-neutral-900 dark:text-neutral-100">About The Archive</Heading>
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-4">
          A personal knowledge base and blog about sustainable living, open-source tech, community, and the mind. Based in Christchurch, NZ.
        </p>
        <a href="/about" class="text-sm font-medium text-neutral-900 dark:text-neutral-100 hover:underline flex items-center gap-1 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-neutral-500 dark:focus:ring-offset-neutral-900 rounded w-fit">More about me &rarr;</a>
      </div>

    </div>
  </section>

</Layout>